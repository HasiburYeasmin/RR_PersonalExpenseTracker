rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - createdAt: timestamp (required)
    //   - budget: number (optional)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - userId: string (required, must match auth.uid)
    //   - amount: number (required, positive)
    //   - type: string (required, 'income' or 'expense')
    //   - category: string (required)
    //   - customCategory: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - description: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'category', 'date', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.date is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
